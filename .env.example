# Base URL of the FastAPI backend server.
# The React app uses this to proxy Facebook API calls through the backend,
# keeping the Facebook access token server-side.
#
# Development default: http://localhost:8000
# Set to your production backend URL when deploying.
#
# Copy this file to .env.local (never commit .env.local to version control).
VITE_BACKEND_URL=http://localhost:8000

# Facebook Graph API page access token.
# Used by the **backend** (backend/main.py) to fetch live Facebook posts.
# The React app never sees this token — it calls the backend's /api/posts
# endpoint instead of the Facebook API directly.
#
# How to obtain:
#   1. Go to https://developers.facebook.com/ and open your app.
#   2. Navigate to Tools > Graph API Explorer.
#   3. Generate a Page Access Token with pages_read_engagement permission.
#   4. Copy the token and paste it below.
#
# Copy this file to .env.local (never commit .env.local to version control).
VITE_FB_ACCESS_TOKEN=your_page_access_token_here

# Node.js / Express test server (scripts/test.cjs) reads this variable too.
FB_ACCESS_TOKEN=your_page_access_token_here
